---
// Renders the Server Moderation List table from src/data/defederation-list.txt.
// Edit that file to update the list; this component re-renders it at build time.
import raw from '../data/defederation-list.txt?raw';

const rows = raw
  .split('\n')
  .map((line) => line.trim())
  .filter((line) => line.length > 0 && !line.startsWith('#'))
  .map((line) => {
    const first = line.indexOf(',');
    const second = line.indexOf(',', first + 1);
    return {
      instance: line.slice(0, first).trim(),
      action: line.slice(first + 1, second).trim(),
      reason: line.slice(second + 1).trim(),
    };
  });
---

<table>
  <thead>
    <tr>
      <th>Instance</th>
      <th>Action</th>
      <th>Reason</th>
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          <td>{row.instance}</td>
          <td>{row.action}</td>
          <td>{row.reason}</td>
        </tr>
      ))
    }
  </tbody>
</table>
